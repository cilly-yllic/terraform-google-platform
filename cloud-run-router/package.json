{
  "name": "cloud-run-router",
  "version": "0.1.0",
  "description": "TFC notification → GitHub repository_dispatch Cloud Run router (reference implementation)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src test",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt src test",
    "fmt:check": "oxfmt --check src test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
