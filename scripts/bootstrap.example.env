# Bootstrap project
BOOTSTRAP_PROJECT_ID="infra-bootstrap"
BOOTSTRAP_PROJECT_NAME="infra-bootstrap"

# Billing account for infra-bootstrap itself.
# Billing Account itself is managed outside this script.
BILLING_ACCOUNT_ID="XXXXXX-XXXXXX-XXXXXX"

# 各サービス (firebase project) が使う billing account の ID を空白区切りで列挙。
# folder mode では bootstrap が org-level billing.user を付けないため、Factory SA
# にこれらの billing account への roles/billing.user を個別付与する必要がある。
# 列挙後 `make grant-billing` (無引数) で全件まとめて付与できる。
# 単一だけ付与したい場合は `make grant-billing BILLING=<id>`。
# SERVICE_BILLING_ACCOUNT_IDS="XXXXXX-XX1111-X11111 123456-123456-123456"

# 配置 (placement)。以下の 3 モードのいずれか:
#
#   1. FOLDER_NAME + ORGANIZATION_ID  ★推奨 / 一番楽
#        ORGANIZATION_ID 配下から FOLDER_NAME (display name) の folder を検索し、
#        無ければ作成して FOLDER_ID を自動解決 → .env に書き戻す。
#        folder ID は GCP 自動採番のため自分では決められない。display name で
#        find-or-create する。要 caller 権限: roles/resourcemanager.folderCreator (org)。
#
#   2. FOLDER_ID + (ORGANIZATION_ID)  既存 folder を直接指定する場合
#
#   3. ORGANIZATION_ID のみ           folder を使わない org 直下運用
#
# folder mode (1 / 2) では Factory SA の projectCreator / projectIamAdmin が
# その folder 内に限定され、Factory SA が触れる範囲 (blast radius) を封じ込められる
# ため **推奨**。org-direct (3) でも動作するが Factory SA の到達範囲が org 全体に
# なる (security floor は factory workspace 限定で別途確保。
# docs/project-bootstrap/design/iam-policy.md 参照)。
ORGANIZATION_ID=""
FOLDER_NAME="infra"   # 例: "infra"。空にすると find-or-create を行わない
FOLDER_ID=""          # FOLDER_NAME 解決時に自動で書き込まれる (手動指定も可)

# Terraform Project Factory Service Account
TERRAFORM_PROJECT_FACTORY_SA_ID="terraform-project-factory"
TERRAFORM_PROJECT_FACTORY_SA_DISPLAY_NAME="Terraform Project Factory"

# Workload Identity Federation
WORKLOAD_IDENTITY_POOL_ID="terraform-cloud"
WORKLOAD_IDENTITY_POOL_DISPLAY_NAME="Terraform Cloud"

WORKLOAD_IDENTITY_PROVIDER_ID="terraform-cloud"
WORKLOAD_IDENTITY_PROVIDER_DISPLAY_NAME="Terraform Cloud"

# Terraform Cloud / HCP Terraform
# Used only for restricting OIDC access by Terraform Cloud organization.
TFC_ORGANIZATION_NAME="example-terraform-cloud-org"

# Factory workspace 命名 prefix (optional)
# Factory SA を impersonate できる workspace を「この prefix で始まる名前」に
# 限定するための派生属性 terraform_workspace_kind の判定に使う。
# default は dispatch-project-bootstrap action の workspace 名と一致する
# "project-factory-"。命名を変える場合のみ設定する。
# FACTORY_WORKSPACE_PREFIX="project-factory-"

# Behavior
CONFIRM_BEFORE_APPLY="true"

# Budget (optional)
# Budget is created only when BUDGET_AMOUNT is set.
# BUDGET_AMOUNT="1000"
# BUDGET_CURRENCY="USD"
# BUDGET_DISPLAY_NAME=""                 # default: "${BOOTSTRAP_PROJECT_NAME} Budget"
# BUDGET_SCOPE="project"                 # "project" or "billing-account"
# BUDGET_THRESHOLDS="0.1,0.3,0.5,0.9,1.0"

# ----------------------------------------------------------------------------
# Cloud Run router deploy resources (optional — opt-in)
# ----------------------------------------------------------------------------
# Set ENABLE_CLOUD_RUN_DEPLOY_SETUP=true to also provision:
#   - GitHub Actions WIF Provider (added to the same WIF Pool above)
#   - Cloud Run deploy SA (run.admin, artifactregistry.writer, etc.;
#     serviceAccountTokenCreator は runtime SA リソース限定で付与)
#   - Cloud Run runtime SA (secretmanager.secretAccessor)
#   - APIs: run / artifactregistry / cloudbuild / secretmanager / orgpolicy
#   - Org policy 'iam.allowedPolicyMemberDomains' override (allowAll: true)
#     scoped to the bootstrap project, so that `gcloud run deploy
#     --allow-unauthenticated` can actually bind allUsers as run.invoker.
#     Required for TFC notification verification POST to succeed on the
#     Router's /webhook (HMAC-verified at app layer; see
#     cloud-run-router/src/routes/webhook/index.ts).
#     ※ Caller needs roles/orgpolicy.policyAdmin granted at the
#       ORGANIZATION or FOLDER scope (the role cannot be granted at the
#       project scope). See scripts/README.md "事前権限 (caller 側)" for
#       the gcloud command.
# Re-running the script is safe (already-created resources are skipped).
#
# ENABLE_CLOUD_RUN_DEPLOY_SETUP="true"
# GITHUB_REPOSITORY="cilly-yllic/terraform-google-platform"   # owner/repo (deploy SA binding = この repo 限定)
# GITHUB_WIF Provider の attribute-condition は org (repository_owner) 単位。
# 未指定なら GITHUB_REPOSITORY の owner を使う。サービス repo が別 owner の場合のみ明示。
# GITHUB_OWNER="cilly-yllic"
# CLOUD_RUN_DEPLOY_SA_ID="cloud-run-router-deploy"
# CLOUD_RUN_DEPLOY_SA_DISPLAY_NAME="Cloud Run Router Deploy"
# CLOUD_RUN_RUNTIME_SA_ID="cloud-run-router-runtime"
# CLOUD_RUN_RUNTIME_SA_DISPLAY_NAME="Cloud Run Router Runtime"
# GITHUB_WIF_PROVIDER_ID="github-actions"
# GITHUB_WIF_PROVIDER_DISPLAY_NAME="GitHub Actions"

# ----------------------------------------------------------------------------
# Cloud Run router runtime secret sync (optional, DEPRECATED の fallback 用途)
# ----------------------------------------------------------------------------
# 通常運用では deploy workflow が GitHub Secrets (TFC_NOTIFICATION_SECRET /
# GH_APP_PRIVATE_KEY) を GCP Secret Manager に自動 sync するため、
# この設定は不要。
#
# 以下の DEPRECATED make ターゲットを使う場合のみ設定:
#   make setup-router-hmac / rotate-router-hmac / sync-router-hmac
#
# GH_ORG を設定 → org-level secret (visibility=selected) で一括登録
# GH_ORG 未設定 → repo-level secret として各 repo に個別 set (drift しやすい)
# 両モードとも TFC_NOTIFICATION_SECRET_REPOS が空なら GitHub 同期はスキップ。
#
# GH_ORG="your-org"
# TFC_NOTIFICATION_SECRET_REPOS="your-org/service1 your-org/service2"
