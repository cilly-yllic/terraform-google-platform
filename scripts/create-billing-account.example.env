# Billing Account creation
# Display name for the new billing account.
BILLING_DISPLAY_NAME="My Project Billing"

# Master (parent) billing account ID.
# The new billing account will be created as a sub-account under this master account.
# Requires `billing.accounts.create` permission on the master billing account.
MASTER_BILLING_ACCOUNT_ID="XXXXXX-XXXXXX-XXXXXX"

# (Optional) GCP Organization numeric ID.
# If set, the billing account will be associated with this organization.
ORGANIZATION_ID=""

# Behavior
CONFIRM_BEFORE_APPLY="true"
